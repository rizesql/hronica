---
import Basic from "./basic.astro";
import Columns from "./columns.astro";

import type { ArticleData } from "~/lib/articles";

export type Props = {
	layout: "basic" | "columns";
	article: ArticleData;
};

const { layout, article } = Astro.props;

const Elem = {
	basic: Basic,
	columns: Columns,
}[layout];
---

<Elem article={article} />
