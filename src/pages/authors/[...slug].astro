---
import { getCollection, type CollectionEntry } from "astro:content";

import { AuthorFeed } from "~/components/feed";
import Layout from "~/components/layouts/home/layout.astro";
import { articles } from "~/lib/articles";
import { filterByAuthor } from "~/lib/articles/helpers";

export const getStaticPaths = async () => {
	const authors = await getCollection("authors");

	return authors.map((author) => ({
		params: { slug: author.id },
		props: { author },
	}));
};

export type Props = {
	author: CollectionEntry<"authors">;
};

const { author } = Astro.props;

const filter = filterByAuthor(author.id);

const feedParams = {
	articlesCount: await articles.pagesCount(filter),
	author: author.id,
};

const firstPage = await articles.loadNext(feedParams, filter)({ pageParam: 0 });

const initialData = {
	pageParams: [0],
	pages: [firstPage],
};
---

<Layout>
	<!-- TODO once i have enough data about an author, make a short thing about it -->
	<pre>{JSON.stringify(author, null, 2)}</pre>
	<AuthorFeed client:load feedParams={feedParams} initialData={initialData} />
</Layout>
