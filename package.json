    "lint:prettier": "prettier --check --plugin-search-dir=. .",
    "lint:eslint": "eslint \"**/*.{js,ts,jsx,tsx,mjs,cjs,astro}\"",
    "lint:typescript": "tsc -b",
    "lint:astro": "astro check",
    "launch:unlighthouse": "pnpm dlx unlighthouse --site http://127.0.0.1:4321"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^7.5.1",
    "@astrojs/markdoc": "^0.5.2",
    "@astrojs/node": "^6.0.3",
