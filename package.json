{
  "name": "hronica",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1",
    "start": "astro dev",
    "build": "astro build && pnpm run postbuild",
    "preview": "astro preview",
    "astro": "astro",
    "format": "pnpm run /^format:/",
    "format:prettier": "prettier -w --plugin-search-dir=. .",
